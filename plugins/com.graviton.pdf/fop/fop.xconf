<fop version="1.0">
  <renderers>
    <renderer mime="application/pdf">
      <fonts>
        <font embed-url="resources/fonts/Roboto-Regular.ttf">
          <font-triplet name="Roboto" style="normal" weight="normal"/>
        </font>
        <font embed-url="resources/fonts/Roboto-Bold.ttf">
          <font-triplet name="Roboto" style="normal" weight="bold"/>
        </font>
      </fonts>
    </renderer>
  </renderers>
</fop>